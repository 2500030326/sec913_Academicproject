# Environment Configuration Template

# Copy this file to .env.local and fill in with your values

# API Configuration
REACT_APP_API_BASE_URL=http://localhost:8080/api
REACT_APP_API_TIMEOUT=30000

# Search Configuration
REACT_APP_SEARCH_API_URL=http://localhost:8080/api/search
REACT_APP_AI_SEMANTIC_SEARCH=true

# Analytics Configuration
REACT_APP_ANALYTICS_ID=your-analytics-id
REACT_APP_TRACKING_ENABLED=true

# Feature Flags
REACT_APP_ENABLE_AI_FEATURES=true
REACT_APP_ENABLE_USER_DASHBOARD=true
REACT_APP_ENABLE_ADMIN_PANEL=true
REACT_APP_ENABLE_NOTIFICATIONS=true

# Social Media
REACT_APP_SHARE_TWITTER=true
REACT_APP_SHARE_FACEBOOK=true
REACT_APP_SHARE_LINKEDIN=true

# Authentication
REACT_APP_AUTH_PROVIDER=local
REACT_APP_AUTH_URL=http://localhost:8080/auth

# Third Party Services
REACT_APP_WEATHER_API_KEY=your-api-key
REACT_APP_NOTIFICATION_SERVICE=pusher

# Development
REACT_APP_DEBUG_MODE=false
REACT_APP_LOG_LEVEL=info
